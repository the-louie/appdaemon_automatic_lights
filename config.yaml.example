# Automatic Lights - Home Assistant AppDaemon Configuration Example
# Copyright (c) 2025 the_louie

automatic_lights:
  module: i1_automatic_lights
  class: AutomaticLights

  # Time-based configuration
  morning_start: "05:30"
  late_morning_start: "06:40"   # Optional: bedroom lights etc.
  early_night_start: "21:30"    # Optional: dim before full night
  night_start: "23:30"

  # Optional solar radiation configuration
  solar_radiation:
    sensor: "sensor.outdoor_light_level"
    threshold: 500
    elevation_threshold: 3.0

  # Staggering configuration for natural light transitions
  staggering:
    light_delay_min: 2    # seconds between individual lights in the same area
    light_delay_max: 5    # seconds between individual lights in the same area
    room_delay_min: 30    # seconds between different areas
    room_delay_max: 120   # seconds between different areas

  # Scene configurations
  # State order: night → morning → late_morning → day → evening → early_night → night
  # Scenes are cumulative: each scene only defines the groups it changes.
  # Groups not listed in a scene retain their state from earlier transitions.
  # On init/restart, the app replays all predecessor scenes up to the current
  # state to reconstruct the correct cumulative lighting state.
  scenes:
    night:
      group.specific_lighting: false
      group.general_lighting: false
      group.night_lighting: true
      group.bedroom: false
    morning:
      group.general_lighting: true
      group.night_lighting: true
    late_morning:
      group.bedroom: true
    day:
      group.general_lighting: false
      group.night_lighting: false
      group.bedroom: false
    evening:
      group.general_lighting: true
      group.night_lighting: true
      group.bedroom: true
    early_night:
      group.bedroom: false
